# PhantomSense Hub - Environment Configuration
# Copy this file to .env and customize for your setup

# ==================== MQTT Configuration ====================
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_USERNAME=phantomsense
MQTT_PASSWORD=phantom_pass

# ==================== Ollama Configuration ====================
OLLAMA_HOST=http://localhost:11434

# ==================== API Configuration ====================
API_HOST=0.0.0.0
API_PORT=5000
DEBUG=False

# ==================== Logging ====================
LOG_LEVEL=INFO

# ==================== Franklin-specific ====================
# Uncomment to force specific GPU
# CUDA_VISIBLE_DEVICES=0
# HIP_VISIBLE_DEVICES=0
